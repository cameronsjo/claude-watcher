# Claude API
WATCHER_ANTHROPIC_API_KEY=sk-ant-...

# Discord webhook
WATCHER_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Email (SMTP) — Postmark recommended
WATCHER_SMTP_HOST=smtp.postmarkapp.com
WATCHER_SMTP_PORT=587
WATCHER_SMTP_USERNAME=your-server-api-token
WATCHER_SMTP_PASSWORD=your-server-api-token
WATCHER_EMAIL_FROM=watcher@yourdomain.com
# Comma-separated list of recipients
WATCHER_EMAIL_TO=["you@personal.com","you@work.com"]

# Schedule (optional, defaults shown)
# WATCHER_CHANGELOG_PEAK_INTERVAL_HOURS=1
# WATCHER_CHANGELOG_OFFPEAK_INTERVAL_HOURS=4
# WATCHER_DOCS_CHECK_HOUR_UTC=6

# Logging
# WATCHER_LOG_LEVEL=INFO
