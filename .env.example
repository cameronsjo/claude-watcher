# Claude API
WATCHER_ANTHROPIC_API_KEY=sk-ant-...

# Discord webhook
WATCHER_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Email (SMTP)
WATCHER_SMTP_HOST=smtp.gmail.com
WATCHER_SMTP_PORT=587
WATCHER_SMTP_USERNAME=you@gmail.com
WATCHER_SMTP_PASSWORD=app-password-here
WATCHER_EMAIL_FROM=you@gmail.com
WATCHER_EMAIL_TO=you@gmail.com

# Schedule (optional, defaults shown)
# WATCHER_CHANGELOG_PEAK_INTERVAL_HOURS=1
# WATCHER_CHANGELOG_OFFPEAK_INTERVAL_HOURS=4
# WATCHER_DOCS_CHECK_HOUR_UTC=6

# Logging
# WATCHER_LOG_LEVEL=INFO
